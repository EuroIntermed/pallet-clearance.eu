---
/**
 * ThemeToggle — flips light/dark by stamping data-theme on <html> and persisting
 * the choice in localStorage. An inline head script (in BaseLayout) applies the
 * saved theme before paint to avoid a flash. Defaults to the OS preference.
 */
import type { Locale } from '../i18n/ui'
import { t } from '../i18n/utils'
const { locale } = Astro.props as { locale: Locale }
const label = t(locale).theme.toggle
---

<button class="ei-theme-toggle" type="button" data-theme-toggle aria-label={label} title={label}>
  <svg class="ei-theme-toggle__sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
  <svg class="ei-theme-toggle__moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
  </svg>
</button>

<style>
  .ei-theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--ei-hairline);
    border-radius: var(--ei-radius-pill);
    background: var(--ei-surface);
    color: var(--ei-ink-soft);
    cursor: pointer;
    transition: border-color 0.2s var(--ei-ease), color 0.2s var(--ei-ease), background 0.2s;
  }
  .ei-theme-toggle:hover {
    border-color: var(--ei-accent);
    color: var(--ei-accent);
  }
  .ei-theme-toggle__moon {
    display: none;
  }
  :global(:root[data-theme='dark']) .ei-theme-toggle__sun {
    display: none;
  }
  :global(:root[data-theme='dark']) .ei-theme-toggle__moon {
    display: block;
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .ei-theme-toggle__sun {
      display: none;
    }
    :global(:root:not([data-theme='light'])) .ei-theme-toggle__moon {
      display: block;
    }
  }
</style>

<script>
  const btn = document.querySelector('[data-theme-toggle]')
  btn?.addEventListener('click', () => {
    const root = document.documentElement
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
    const current = root.dataset.theme || (prefersDark ? 'dark' : 'light')
    const next = current === 'dark' ? 'light' : 'dark'
    root.dataset.theme = next
    try {
      localStorage.setItem('ei-theme', next)
    } catch {
      /* storage may be blocked; theme still applies for this session */
    }
  })
</script>
