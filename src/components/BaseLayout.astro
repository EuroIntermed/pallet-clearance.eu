---
/**
 * BaseLayout — the single HTML shell for every PalletClearance page.
 *
 * Identical structure to the Euro-Intermed hub + Angrosist shells; the only theme
 * switch is `data-vertical="palletclearance"` on <html>, which selects the
 * AMBER/TERRACOTTA accent layer from the shared global.css (Hard Rule: one shared
 * design system, swappable accent).
 *
 * Responsibilities:
 *  - <head>: title, meta description, canonical, OpenGraph + Twitter, hreflang
 *    (RO/EN + x-default), JSON-LD WebSite (+ publisher Organization), favicon.
 *  - Pre-paint theme script (applies the saved light/dark choice, no flash).
 *  - Self-hosted DM Sans variable font (no Google Fonts CDN — GDPR).
 *  - Env-driven injection of GA4 Consent Mode (Analytics) and the chat widget,
 *    plus the cookie banner — the latter two only when their env is set.
 *  - Nav + Footer chrome around the page slot.
 */
import '@fontsource-variable/dm-sans'
import '../styles/global.css'
import type { Locale } from '../i18n/ui'
import { t, switchLocalePath, htmlLang, ogLocale } from '../i18n/utils'
import {
  siteUrl,
  analyticsEnabled,
  contactEmail,
  contactPhone,
  verticalUrls,
  socialLinks,
  googleSiteVerification,
} from '../lib/config'
import { ogSlug } from '../lib/og'
import { faqSchema, breadcrumbSchema, type FaqItem } from '../lib/schema'
import Nav from './Nav.astro'
import Footer from './Footer.astro'
import Analytics from './Analytics.astro'
import CookieBanner from './CookieBanner.astro'
import Widget from './Widget.astro'

interface Props {
  locale: Locale
  title: string
  description: string
  /** OpenGraph type; defaults to "website". */
  ogType?: string
  /** Hide the footer (e.g. for the 404). */
  bare?: boolean
  /** FAQ items for a homepage FAQPage node (omit → no FAQPage emitted). */
  faqItems?: FaqItem[]
  /** Leaf breadcrumb label for a non-home page (omit → no BreadcrumbList). */
  breadcrumb?: string
}
const {
  locale,
  title,
  description,
  ogType = 'website',
  bare = false,
  faqItems,
  breadcrumb,
} = Astro.props

const nav = t(locale).nav
const path = Astro.url.pathname
const canonical = new URL(path, siteUrl).href
const roUrl = new URL(switchLocalePath(path, 'ro'), siteUrl).href
const enUrl = new URL(switchLocalePath(path, 'en'), siteUrl).href
// Branded 1200x630 social card generated at build (see src/pages/og + src/lib/og).
// Absolute URL from the env-driven siteUrl — no hardcoded host (Hard Rule #1).
const ogImage = new URL(`/og/${ogSlug(path, locale)}.png`, siteUrl).href
// Absolute logo for the Organization node (Hard Rule #1 — from env-driven origin).
const logoUrl = new URL('/favicon.svg', siteUrl).href

// JSON-LD: PalletClearance WebSite, published by the Euro-Intermed operating company.
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'PalletClearance.eu',
  url: siteUrl,
  inLanguage: htmlLang[locale],
  publisher: {
    '@type': 'Organization',
    name: 'EURO INTERMED SOLUTIONS',
    logo: logoUrl,
    email: contactEmail,
    telephone: contactPhone,
    url: verticalUrls.hub,
    vatID: 'RO39132147',
    identifier: 'J8/735/2018',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Brașov',
      addressCountry: 'RO',
    },
    // Env-configured official social profiles only (empty → omitted).
    ...(socialLinks.length ? { sameAs: socialLinks } : {}),
  },
}

// Optional per-page structured data (built from env-driven absolute URLs).
const faqJsonLd = faqItems ? faqSchema(faqItems) : null
const breadcrumbJsonLd = breadcrumb
  ? breadcrumbSchema([
      { name: nav.home, url: new URL(switchLocalePath('/', locale), siteUrl).href },
      { name: breadcrumb, url: canonical },
    ])
  : null
---

<!doctype html>
<html lang={htmlLang[locale]} data-locale={locale} data-vertical="palletclearance">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Apply the saved theme before paint to avoid a flash. -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('ei-theme')
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.dataset.theme = saved
          }
        } catch (e) {}
      })()
    </script>

    <!-- GA4 + Consent Mode v2 (only when GA_MEASUREMENT_ID is set). -->
    <Analytics />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    <meta name="theme-color" content="#faf9f5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#26150b" media="(prefers-color-scheme: dark)" />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ro" href={roUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={roUrl} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- OpenGraph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="PalletClearance.eu" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={ogLocale[locale]} />
    <meta property="og:locale:alternate" content={ogLocale[locale === 'ro' ? 'en' : 'ro']} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(siteJsonLd)} />
    {faqJsonLd && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />
    )}
    {breadcrumbJsonLd && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
    )}

    <slot name="head" />
  </head>

  <body>
    <a class="ei-skip-link" href="#main">{nav.skip}</a>
    <Nav locale={locale} />
    <main id="main">
      <slot />
    </main>
    {!bare && <Footer locale={locale} />}

    {analyticsEnabled && <CookieBanner locale={locale} />}
    <Widget locale={locale} />

    <script>
      import '../scripts/site.ts'
    </script>
  </body>
</html>

<style is:global>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  main {
    flex: 1 0 auto;
  }
</style>
