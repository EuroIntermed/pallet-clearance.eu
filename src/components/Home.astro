---
/**
 * Home — full homepage body for a single locale (rendered by /index.astro and
 * /en/index.astro). PalletClearance spine:
 *   hero → TWO-PATH split (Sell / Buy, each with its own WhatsApp CTA) →
 *   what-we-handle → no-public-listings (confidentiality) → 4-step how-it-works →
 *   trust strip → ecosystem cross-links (hub + siblings) → FAQ → WhatsApp CTA.
 * There is NO public catalog/offers listing — offers stay confidential.
 * All copy comes from the i18n dictionary; ecosystem URLs come from env.
 */
import type { Locale } from '../i18n/ui'
import { t, localizePath } from '../i18n/utils'
import { verticalUrls, waLink } from '../lib/config'
import BaseLayout from './BaseLayout.astro'
import Hero from './Hero.astro'
import Section from './Section.astro'
import Card from './Card.astro'
import Button from './Button.astro'
import FAQ from './FAQ.astro'

const { locale } = Astro.props as { locale: Locale }
const c = t(locale)
const contactHref = localizePath('/contact', locale)
const howHref = localizePath('/cum-functioneaza', locale)

// Ecosystem cross-links — destinations from env (Hard Rule #1).
const pillarLinks: Record<string, { url: string; ga: string }> = {
  hub: { url: verticalUrls.hub, ga: 'euro-intermed' },
  angrosist: { url: verticalUrls.angrosist, ga: 'angrosist' },
  skalyou: { url: verticalUrls.skalyou, ga: 'skalyou' },
}

const paths = [
  {
    kind: 'seller',
    data: c.paths.seller,
    wa: c.hero.sellWaText,
  },
  {
    kind: 'buyer',
    data: c.paths.buyer,
    wa: c.hero.buyWaText,
  },
]
---

<BaseLayout locale={locale} title={c.meta.homeTitle} description={c.meta.homeDescription} faqItems={c.faq.items}>
  <Hero locale={locale} />

  <!-- TWO-PATH split — the signature PalletClearance section -->
  <Section id="paths" tone="raised" labelledby="paths-title">
    <div class="ei-head ei-head--center" data-reveal>
      <p class="ei-eyebrow">{c.paths.eyebrow}</p>
      <h2 id="paths-title">{c.paths.title}</h2>
      <p class="ei-lead">{c.paths.copy}</p>
    </div>
    <div class="pc-paths">
      {
        paths.map((p, i) => (
          <article class={`pc-path pc-path--${p.kind}`} data-reveal style={`--i:${i}`}>
            <span class="pc-path__tag">{p.data.tag}</span>
            <h3 class="pc-path__title">{p.data.title}</h3>
            <p class="pc-path__body">{p.data.body}</p>
            <ul class="pc-path__points">
              {p.data.points.map((pt) => (
                <li>
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  <span>{pt}</span>
                </li>
              ))}
            </ul>
            <p class="pc-path__note">{p.data.note}</p>
            <div class="pc-path__actions">
              <Button href={waLink(p.wa)} variant="whatsapp" target="_blank" rel="noopener" data-ga-vertical="whatsapp">
                {p.data.cta}
              </Button>
              <Button href={howHref} variant="ghost" size="sm">{c.process.cta} &rarr;</Button>
            </div>
          </article>
        ))
      }
    </div>
  </Section>

  <!-- What we handle (no catalog — types of stock only) -->
  <Section id="what-we-handle" labelledby="handle-title">
    <div class="ei-head" data-reveal>
      <p class="ei-eyebrow">{c.handle.eyebrow}</p>
      <h2 id="handle-title">{c.handle.title}</h2>
      <p class="ei-lead">{c.handle.copy}</p>
    </div>
    <div class="ei-grid ei-grid--3">
      {
        c.handle.items.map((item, i) => (
          <Card badge={item.tag} title={item.name} index={i}>
            <p>{item.body}</p>
          </Card>
        ))
      }
    </div>
  </Section>

  <!-- No public listings / confidentiality -->
  <Section id="confidential" tone="raised" labelledby="conf-title">
    <div class="pc-conf">
      <div class="pc-conf__head" data-reveal>
        <p class="ei-eyebrow">{c.confidential.eyebrow}</p>
        <h2 id="conf-title">{c.confidential.title}</h2>
        <p class="ei-lead">{c.confidential.copy}</p>
      </div>
      <ul class="pc-conf__grid" data-reveal>
        {
          c.confidential.benefits.map((b) => (
            <li>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              <span>{b}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </Section>

  <!-- How it works (4 steps) -->
  <Section id="how-we-work" labelledby="proc-title">
    <div class="ei-head ei-head--center" data-reveal>
      <p class="ei-eyebrow">{c.process.eyebrow}</p>
      <h2 id="proc-title">{c.process.title}</h2>
    </div>
    <ol class="ei-steps">
      {
        c.process.steps.map((step, i) => (
          <li class="ei-step" data-reveal style={`--i:${i}`}>
            <span class="ei-step__n" aria-hidden="true">{i + 1}</span>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </li>
        ))
      }
    </ol>
    <div class="ei-head__cta ei-head__cta--center" data-reveal>
      <Button href={howHref} variant="secondary">{c.process.cta} &rarr;</Button>
    </div>
  </Section>

  <!-- Trust strip -->
  <Section tone="raised" labelledby="trust-title">
    <div class="ei-head ei-head--center" data-reveal>
      <p class="ei-eyebrow">{c.trust.eyebrow}</p>
      <h2 id="trust-title">{c.trust.title}</h2>
    </div>
    <div class="ei-grid ei-grid--3">
      {
        c.trust.items.map((item, i) => (
          <Card title={item.title} index={i}>
            <p>{item.body}</p>
          </Card>
        ))
      }
    </div>
  </Section>

  <!-- Ecosystem cross-links -->
  <Section id="ecosystem" tone="contrast" labelledby="eco-title">
    <div class="ei-head ei-head--center" data-reveal>
      <p class="ei-eyebrow">{c.ecosystem.eyebrow}</p>
      <h2 id="eco-title">{c.ecosystem.title}</h2>
      <p class="ei-lead">{c.ecosystem.copy}</p>
    </div>
    <div class="ei-grid ei-grid--3">
      {
        c.ecosystem.pillars.map((p, i) => {
          const link = pillarLinks[p.key]
          return (
            <Card variant="pillar" roadmap={p.roadmap} badge={p.badge} title={p.name} index={i}>
              <p class="ei-pillar-line">{p.line}</p>
              <div class="ei-card__pillar-actions">
                <Button
                  href={link.url}
                  variant={p.roadmap ? 'ghost' : 'secondary'}
                  size="sm"
                  target="_blank"
                  rel="noopener"
                  data-ga-vertical={link.ga}
                >
                  {p.cta} &rarr;
                </Button>
              </div>
            </Card>
          )
        })
      }
    </div>
  </Section>

  <!-- FAQ -->
  <Section id="faq" labelledby="faq-title">
    <div class="ei-head ei-head--center" data-reveal>
      <p class="ei-eyebrow">{c.faq.eyebrow}</p>
      <h2 id="faq-title">{c.faq.title}</h2>
    </div>
    <FAQ items={c.faq.items} />
  </Section>

  <!-- Final WhatsApp CTA -->
  <Section id="contact" tone="contrast" labelledby="cta-title">
    <div class="ei-cta" data-reveal>
      <p class="ei-eyebrow">{c.contactCta.eyebrow}</p>
      <h2 id="cta-title">{c.contactCta.title}</h2>
      <p class="ei-lead">{c.contactCta.copy}</p>
      <div class="ei-cta__actions">
        <Button href={waLink(c.hero.whatsappText)} variant="whatsapp" target="_blank" rel="noopener" data-ga-vertical="whatsapp">
          {c.contactCta.primary}
        </Button>
        <Button href={contactHref} variant="secondary">{c.contactCta.secondary}</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .ei-head {
    max-width: 60ch;
    margin-bottom: 2.5rem;
  }
  .ei-head--center {
    margin-inline: auto;
    text-align: center;
  }
  .ei-head--center .ei-lead {
    margin-inline: auto;
  }
  .ei-head h2 {
    margin-top: 0.7rem;
  }
  .ei-head .ei-lead {
    margin-top: 1rem;
  }
  .ei-head__cta {
    margin-top: 2rem;
  }
  .ei-head__cta--center {
    text-align: center;
  }

  .ei-grid {
    display: grid;
    gap: 1.25rem;
  }
  .ei-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .ei-pillar-line {
    font-size: 1.02rem;
  }

  /* Two-path split */
  .pc-paths {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .pc-path {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: clamp(1.6rem, 1.2rem + 1.4vw, 2.4rem);
    background: var(--ei-surface);
    border: 1px solid var(--ei-hairline);
    border-radius: var(--ei-radius-lg);
    box-shadow: var(--ei-shadow-sm);
    overflow: hidden;
    transition: transform 0.3s var(--ei-ease-out), box-shadow 0.3s var(--ei-ease), border-color 0.3s var(--ei-ease);
  }
  .pc-path::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, var(--ei-accent), var(--ei-gold));
  }
  .pc-path:hover {
    transform: translateY(-4px);
    box-shadow: var(--ei-shadow-lg);
    border-color: var(--ei-accent);
  }
  .pc-path__tag {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    padding: 0.3em 0.85em;
    border-radius: var(--ei-radius-pill);
    background: var(--ei-accent-soft);
    color: var(--ei-accent-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pc-path__title {
    font-size: 1.5rem;
    letter-spacing: -0.02em;
  }
  .pc-path__body {
    color: var(--ei-muted);
    text-wrap: pretty;
  }
  .pc-path__points {
    list-style: none;
    margin: 0.2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .pc-path__points li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.94rem;
    color: var(--ei-ink-soft);
  }
  .pc-path__points svg {
    flex: 0 0 auto;
    color: var(--ei-accent);
  }
  .pc-path__note {
    margin-top: 0.2rem;
    padding-top: 0.8rem;
    border-top: 1px dashed var(--ei-hairline);
    font-size: 0.88rem;
    color: var(--ei-faint);
  }
  .pc-path__actions {
    margin-top: auto;
    padding-top: 0.6rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
  }

  /* Confidentiality strip */
  .pc-conf {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 1rem + 3vw, 3.5rem);
    align-items: center;
  }
  .pc-conf__head h2 {
    margin-top: 0.7rem;
  }
  .pc-conf__head .ei-lead {
    margin-top: 1rem;
  }
  .pc-conf__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .pc-conf__grid li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.95rem 1.1rem;
    background: var(--ei-surface);
    border: 1px solid var(--ei-hairline);
    border-radius: var(--ei-radius-sm);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ei-ink-soft);
  }
  .pc-conf__grid svg {
    flex: 0 0 auto;
    color: var(--ei-accent);
  }

  /* Process steps */
  .ei-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    counter-reset: step;
  }
  .ei-step {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.6rem 1.5rem;
    background: var(--ei-surface);
    border: 1px solid var(--ei-hairline);
    border-radius: var(--ei-radius-md);
  }
  .ei-step__n {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--ei-accent-soft);
    color: var(--ei-accent-text);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .ei-step h3 {
    font-size: 1.08rem;
  }
  .ei-step p {
    color: var(--ei-muted);
    font-size: 0.94rem;
  }

  /* Contact CTA */
  .ei-cta {
    max-width: 60ch;
    margin-inline: auto;
    text-align: center;
  }
  .ei-cta h2 {
    margin-top: 0.7rem;
  }
  .ei-cta .ei-lead {
    margin: 1rem auto 0;
  }
  .ei-cta__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .ei-cta__actions :global(.ei-btn--secondary),
  .ei-cta__actions :global(.ei-btn--ghost) {
    --_fg: var(--ei-on-contrast);
    --_bd: rgba(255, 255, 255, 0.35);
  }
  .ei-cta__actions :global(.ei-btn--secondary:hover) {
    --_bg: rgba(255, 255, 255, 0.1);
    --_bd: var(--ei-on-contrast);
    --_fg: var(--ei-on-contrast);
  }

  @media (max-width: 960px) {
    .ei-grid--3 {
      grid-template-columns: repeat(2, 1fr);
    }
    .ei-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 780px) {
    .pc-paths {
      grid-template-columns: 1fr;
    }
    .pc-conf {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .ei-grid--3 {
      grid-template-columns: 1fr;
    }
    .ei-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
