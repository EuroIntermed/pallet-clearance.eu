---
/**
 * FAQ — accessible accordion. Each item is a <button> controlling a region;
 * aria-expanded reflects state, panels toggle [hidden]. First item open by
 * default. Keyboard operable and reduced-motion safe.
 */
interface Item {
  q: string
  a: string
}
interface Props {
  items: Item[]
}
const { items } = Astro.props as Props
---

<div class="ei-faq" data-faq>
  {
    items.map((item, i) => (
      <div class="ei-faq__item" data-reveal style={`--i:${i}`}>
        <h3 class="ei-faq__heading">
          <button
            class="ei-faq__q"
            type="button"
            aria-expanded={i === 0 ? 'true' : 'false'}
            aria-controls={`ei-faq-a-${i}`}
            id={`ei-faq-q-${i}`}
          >
            <span>{item.q}</span>
            <svg class="ei-faq__chev" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </button>
        </h3>
        <div class="ei-faq__a" id={`ei-faq-a-${i}`} role="region" aria-labelledby={`ei-faq-q-${i}`} hidden={i !== 0}>
          <p>{item.a}</p>
        </div>
      </div>
    ))
  }
</div>

<style>
  .ei-faq {
    max-width: 820px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ei-faq__item {
    border: 1px solid var(--ei-hairline);
    border-radius: var(--ei-radius-md);
    background: var(--ei-surface);
    overflow: hidden;
    transition: border-color 0.25s var(--ei-ease);
  }
  .ei-faq__item:has(.ei-faq__q[aria-expanded='true']) {
    border-color: var(--ei-accent);
    box-shadow: var(--ei-shadow-sm);
  }
  .ei-faq__heading {
    margin: 0;
    font-size: inherit;
  }
  .ei-faq__q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.3rem;
    border: none;
    background: transparent;
    color: var(--ei-ink);
    font-size: 1.02rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-align: left;
    cursor: pointer;
  }
  .ei-faq__chev {
    flex: 0 0 auto;
    color: var(--ei-accent);
    transition: transform 0.3s var(--ei-ease-out);
  }
  .ei-faq__q[aria-expanded='true'] .ei-faq__chev {
    transform: rotate(180deg);
  }
  .ei-faq__a {
    padding: 0 1.3rem 1.2rem;
  }
  .ei-faq__a p {
    margin: 0;
    color: var(--ei-muted);
    max-width: 65ch;
    text-wrap: pretty;
  }
</style>

<script>
  document.querySelectorAll('[data-faq] .ei-faq__q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const panelId = btn.getAttribute('aria-controls')
      const panel = panelId ? document.getElementById(panelId) : null
      const open = btn.getAttribute('aria-expanded') === 'true'
      btn.setAttribute('aria-expanded', String(!open))
      if (panel) panel.hidden = open
    })
  })
</script>
