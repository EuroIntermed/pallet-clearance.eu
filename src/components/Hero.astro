---
/**
 * Hero — badge with pulsing dot, staggered fadeUp headline + lead, the two-path
 * actions (Sell stock → WhatsApp seller flow / Buy lots → the two-path section),
 * a trust line, and the animated HeroPanel visual (the confidential-flow example).
 */
import { t } from '../i18n/utils'
import type { Locale } from '../i18n/ui'
import { waLink } from '../lib/config'
import Button from './Button.astro'
import HeroPanel from './HeroPanel.astro'

const { locale } = Astro.props as { locale: Locale }
const c = t(locale).hero
---

<section class="ei-hero" aria-labelledby="ei-hero-title">
  <div class="ei-hero__bg" aria-hidden="true"></div>
  <div class="ei-hero__wash" aria-hidden="true"></div>
  <svg class="ei-contour ei-hero__contour" viewBox="0 0 1200 620" preserveAspectRatio="xMidYMid slice" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
    <path d="M-40 96 C 220 34 420 156 660 100 S 1040 42 1250 112" />
    <path d="M-40 170 C 220 110 420 232 660 174 S 1040 116 1250 186" />
    <path d="M-40 246 C 200 184 440 308 660 248 S 1060 188 1250 260" />
    <path d="M-40 322 C 220 258 420 382 660 322 S 1040 262 1250 334" />
    <path d="M-40 398 C 200 338 440 456 660 400 S 1060 336 1250 410" />
    <path d="M-40 474 C 220 410 420 532 660 474 S 1040 414 1250 486" />
    <path d="M-40 550 C 200 490 440 606 660 552 S 1060 492 1250 560" />
  </svg>
  <div class="ei-container ei-hero__grid">
    <div class="ei-hero__content">
      <p class="ei-badge" data-hero style="--i:0">
        <span class="ei-badge__dot" aria-hidden="true"></span>
        {c.badge}
      </p>
      <h1 class="ei-hero__title" id="ei-hero-title" data-hero style="--i:1">{c.title}</h1>
      <p class="ei-lead ei-hero__lead" data-hero style="--i:2">{c.lead}</p>
      <div class="ei-hero__actions" data-hero style="--i:3">
        <Button href={waLink(c.sellWaText)} variant="whatsapp" target="_blank" rel="noopener" data-ga-vertical="whatsapp">
          {c.sell}
        </Button>
        <Button href="#paths" variant="secondary">{c.buy}</Button>
      </div>
      <p class="ei-hero__trust" data-hero style="--i:4">{c.trustLine}</p>
    </div>

    <div class="ei-hero__visual" data-hero style="--i:2">
      <!-- Signature motif: stacked pallets + delivery routes, sitting behind the panel. -->
      <svg class="ei-hero__motif" viewBox="0 0 360 360" fill="none" aria-hidden="true">
        <g stroke="var(--ei-accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
          <path d="M60 250h150M60 250v-22h150v22M78 228v-20h114v20M96 208v-18h78v18" />
          <path d="M96 250v-22M138 250v-22M180 250v-22M114 228v-20M156 228v-20M132 208v-18" />
        </g>
        <g stroke="var(--ei-gold)" stroke-width="1.6" stroke-linecap="round" stroke-dasharray="2 9" opacity="0.7">
          <path d="M40 296h280" />
          <path d="M300 92c-70 0-70 60-140 60S90 92 40 152" />
        </g>
        <circle cx="300" cy="92" r="6" fill="var(--ei-gold)" opacity="0.8" />
        <circle cx="40" cy="152" r="6" fill="var(--ei-accent)" opacity="0.8" />
      </svg>
      <HeroPanel locale={locale} />
    </div>
  </div>
</section>

<style>
  .ei-hero {
    position: relative;
    padding-block: clamp(3rem, 2rem + 6vw, 6.5rem) clamp(3.5rem, 2.5rem + 6vw, 7rem);
    overflow: hidden;
  }
  .ei-hero__bg {
    position: absolute;
    inset: -10% -20% auto -20%;
    height: 78%;
    background:
      radial-gradient(38% 46% at 82% 16%, var(--ei-glow), transparent 68%),
      radial-gradient(60% 80% at 78% 30%, var(--ei-accent-soft), transparent 70%),
      radial-gradient(50% 60% at 18% 8%, var(--ei-gold-soft), transparent 70%);
    filter: saturate(0.95);
    pointer-events: none;
  }
  /* Desaturated concrete wash (grayscale hero.webp) — a faint structural texture
     masked into the upper-right, kept far below any text so AA/LCP are untouched. */
  .ei-hero__wash {
    position: absolute;
    inset: -6% -12% auto -12%;
    height: 92%;
    z-index: 0;
    pointer-events: none;
    background: url('/textures/hero.webp') no-repeat right top / cover;
    filter: grayscale(1) contrast(1.04);
    opacity: 0.07;
    mix-blend-mode: luminosity;
    -webkit-mask-image: radial-gradient(58% 64% at 84% 22%, #000 0%, transparent 72%);
    mask-image: radial-gradient(58% 64% at 84% 22%, #000 0%, transparent 72%);
  }
  :root[data-theme='dark'] .ei-hero__wash {
    opacity: 0.06;
  }
  .ei-hero__contour {
    height: 118%;
    inset: -9% 0 auto 0;
  }
  .ei-hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(2rem, 1rem + 4vw, 4.5rem);
  }
  .ei-hero__content {
    max-width: 38rem;
  }
  .ei-hero__title {
    margin-top: 1.1rem;
  }
  .ei-hero__lead {
    margin-top: 1.3rem;
  }
  .ei-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .ei-hero__trust {
    margin-top: 1.4rem;
    font-size: 0.86rem;
    color: var(--ei-faint);
  }
  .ei-hero__visual {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .ei-hero__motif {
    position: absolute;
    z-index: 0;
    width: 128%;
    max-width: none;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -46%);
    pointer-events: none;
  }
  .ei-hero__visual :global(.pc-panel) {
    position: relative;
    z-index: 1;
  }

  /* Hero entrance reveal (fires immediately, not scroll-gated) */
  [data-hero] {
    opacity: 0;
    transform: translateY(24px);
    animation: ei-fade-up 0.8s var(--ei-ease-out) forwards;
    animation-delay: calc(var(--i, 0) * 120ms + 100ms);
  }

  /* Badge with pulsing dot */
  .ei-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    margin: 0;
    padding: 0.45em 0.95em;
    border: 1px solid var(--ei-hairline-strong);
    border-radius: var(--ei-radius-pill);
    background: var(--ei-surface);
    box-shadow: var(--ei-shadow-sm);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--ei-ink-soft);
  }
  .ei-badge__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ei-accent);
    box-shadow: 0 0 0 4px var(--ei-accent-soft);
    animation: ei-badge-dot 2.4s ease-in-out infinite;
  }

  @media (max-width: 880px) {
    .ei-hero__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .ei-hero__visual {
      order: -1;
    }
    .ei-hero__content {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-hero] {
      opacity: 1;
      transform: none;
    }
  }
</style>
